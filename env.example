# DeepWiki local-only setup
# Privacy-first defaults for running entirely on your machine.

# Keep model selection local and hide cloud providers in the UI.
DEEPWIKI_LOCAL_ONLY=true
DEEPWIKI_PROVIDER_ALLOWLIST=ollama
DEEPWIKI_DEFAULT_PROVIDER=ollama
DEEPWIKI_EMBEDDER_TYPE=ollama

# Bind to your local Ollama daemon.
OLLAMA_HOST=http://127.0.0.1:11434

# Suggested local models:
# ollama pull nomic-embed-text
# ollama pull qwen3:1.7b

# Local ports
PORT=8001
API_PORT=8001
SERVER_BASE_URL=http://127.0.0.1:8001
PYTHON_BACKEND_HOST=http://127.0.0.1:8001
